# Copy this file to .env and fill in your values

# MongoDB connection string
# Local:  mongodb://localhost:27017/journal_db
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/journal_db
MONGO_URI=mongodb://localhost:27017/journal_db

# ── Google Gemini API key (FREE — no credit card needed) ──────────────────────
# How to get your free key in 30 seconds:
#   1. Open https://aistudio.google.com/app/apikey
#   2. Click "Create API key"
#   3. Paste it below
# Free tier limits: 15 requests/min, 1 500 req/day — plenty for local dev
#
# If left blank the app uses a built-in mock response so it still runs without a key.
GEMINI_API_KEY=

# Port for the Express server
PORT=5000
